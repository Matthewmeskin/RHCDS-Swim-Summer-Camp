# Country Day Camp Swim Portal — environment variables
# Copy this file to .env.local and fill in your project's values.

# --- Required (client-side, safe to expose: this is the publishable key) ---
NEXT_PUBLIC_SUPABASE_URL=https://aaioiktrlkyexmcbobzx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_CanFJJQueodlsEBK0Sh03Q_-QHrO2iq

# --- Optional (seed script only; SECRET — never commit, never expose client-side) ---
# Used by `npm run seed` to bypass RLS. Found in Supabase: Project Settings > API.
# If omitted, the seed script falls back to the anon key (works with v1 RLS policies).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Optional: availability-request notifications via n8n (Slack + Gmail) ---
# The app POSTs request/decision events here; the n8n workflow sends Slack +
# email. Without it, notifications simply no-op (the in-app flow still works).
# N8N_AVAILABILITY_WEBHOOK=https://your-n8n.example.com/webhook/availability
# NEXT_PUBLIC_SITE_URL=https://rhcds-swim-summer-camp.vercel.app
